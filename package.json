{
  "name": "yourui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/process.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "process": "node --env-file=.env node_modules/.bin/tsx src/process.ts",
    "serve": "tsx src/serve.ts",
    "test": "node --import tsx/esm --test tests/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
